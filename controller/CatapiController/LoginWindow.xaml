<Window x:Class="CatapiController.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Catpaw Login"
        Width="430" Height="570" MinWidth="430" MinHeight="570" MaxWidth="430" MaxHeight="570"
        WindowStartupLocation="CenterOwner" WindowStyle="None" ResizeMode="NoResize"
        ShowInTaskbar="False" Background="#171714"
        FontFamily="Segoe UI,Microsoft YaHei UI" Foreground="{StaticResource TextBrush}"
        Closing="Window_Closing">
    <Window.Resources>
        <Style x:Key="SegmentButton" TargetType="RadioButton">
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
            <Setter Property="Background" Value="#20201C" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Segment" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1"
                                CornerRadius="4" Padding="12,7">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Segment" Property="Background" Value="#343028" />
                                <Setter TargetName="Segment" Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Margin="10" BorderBrush="#45443D" BorderThickness="1" CornerRadius="7"
            Background="{StaticResource WindowBackground}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40" />
                <RowDefinition Height="54" />
                <RowDefinition Height="*" />
                <RowDefinition Height="56" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{StaticResource PanelBackground}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                    CornerRadius="6,6,0,0" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid Margin="13,0,7,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="36" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="18" Height="18" BorderBrush="{StaticResource PrimaryBrush}"
                                BorderThickness="1" CornerRadius="3">
                            <TextBlock Text="C" Foreground="{StaticResource PrimaryBrush}"
                                       FontFamily="Consolas" FontWeight="Bold" FontSize="10"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <TextBlock Text="Catpaw Login" Margin="9,0,0,0" FontWeight="SemiBold"
                                   FontSize="12" VerticalAlignment="Center" />
                    </StackPanel>
                    <Button Grid.Column="1" Content="×" Style="{StaticResource SecondaryButton}"
                            Padding="0" BorderThickness="0" Click="Cancel_Click" ToolTip="Close" />
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="20,10,20,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <RadioButton x:Name="QrModeRadio" Content="二维码  QR" GroupName="LoginMode"
                             IsChecked="True" Style="{StaticResource SegmentButton}"
                             Click="QrMode_Click" />
                <RadioButton x:Name="MobileModeRadio" Grid.Column="2" Content="手机  Mobile"
                             GroupName="LoginMode" Style="{StaticResource SegmentButton}"
                             Click="MobileMode_Click" />
            </Grid>

            <Grid Grid.Row="2" Margin="20,4,20,8">
                <Grid x:Name="QrPanel">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="240" />
                        <RowDefinition Height="54" />
                        <RowDefinition Height="38" />
                        <RowDefinition Height="44" />
                    </Grid.RowDefinitions>
                    <Border Width="240" Height="240" HorizontalAlignment="Center"
                            Background="#F5F5F1" BorderBrush="#4A4941" BorderThickness="1"
                            CornerRadius="4">
                        <Grid>
                            <TextBlock x:Name="QrPlaceholder" Text="Requesting QR..."
                                       Foreground="#77766E" FontFamily="Cascadia Mono,Consolas"
                                       FontSize="11" HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                            <Image x:Name="QrImage" Width="232" Height="232" Stretch="Uniform"
                                   RenderOptions.BitmapScalingMode="HighQuality" />
                        </Grid>
                    </Border>
                    <TextBlock x:Name="QrStateText" Grid.Row="1" Text="准备二维码"
                               TextAlignment="Center" TextWrapping="Wrap" FontSize="12"
                               VerticalAlignment="Center" />
                    <CheckBox x:Name="QrTermsCheckBox" Grid.Row="2"
                              Content="我已阅读并同意 Catpaw 服务条款 / I agree to the terms"
                              Foreground="#D4D2C7" FontSize="10" VerticalAlignment="Center"
                              Checked="QrTerms_Changed" Unchecked="QrTerms_Changed" />
                    <Grid Grid.Row="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button x:Name="OpenBrowserButton" Content="浏览器打开 / Browser"
                                Style="{StaticResource SecondaryButton}" Click="OpenBrowser_Click" />
                        <Button x:Name="RetryQrButton" Grid.Column="2" Content="刷新 / Retry"
                                Style="{StaticResource PrimaryButton}" Click="RetryQr_Click" />
                    </Grid>
                </Grid>

                <Grid x:Name="MobilePanel" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="24" />
                        <RowDefinition Height="66" />
                        <RowDefinition Height="66" />
                        <RowDefinition Height="66" />
                        <RowDefinition Height="42" />
                        <RowDefinition Height="46" />
                    </Grid.RowDefinitions>
                    <TextBlock x:Name="MobileHeading" Text="手机号登录 / Mobile login"
                               FontFamily="Georgia,Microsoft YaHei UI" FontSize="18"
                               FontWeight="SemiBold" />
                    <TextBlock x:Name="BindingNotice" Grid.Row="1"
                               Text="扫码账号需要绑定手机号 / Mobile binding required"
                               Foreground="{StaticResource PrimaryBrush}" FontSize="10"
                               Visibility="Collapsed" />

                    <Grid Grid.Row="2">
                        <Grid.RowDefinitions><RowDefinition Height="20" /><RowDefinition Height="38" /></Grid.RowDefinitions>
                        <TextBlock Text="手机号码  MOBILE" Foreground="{StaticResource MutedBrush}"
                                   FontFamily="Cascadia Mono,Consolas" FontSize="10" />
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="112" /></Grid.ColumnDefinitions>
                            <TextBox x:Name="MobileTextBox" MaxLength="11" VerticalContentAlignment="Center"
                                     TextChanged="MobileTextBox_TextChanged" />
                            <Button x:Name="SendSmsButton" Grid.Column="1" Margin="8,0,0,0"
                                    Content="发送验证码" Style="{StaticResource SecondaryButton}"
                                    Padding="8,6" Click="SendSms_Click" />
                        </Grid>
                    </Grid>

                    <Grid Grid.Row="3">
                        <Grid.RowDefinitions><RowDefinition Height="20" /><RowDefinition Height="38" /></Grid.RowDefinitions>
                        <TextBlock Text="短信验证码  SMS CODE" Foreground="{StaticResource MutedBrush}"
                                   FontFamily="Cascadia Mono,Consolas" FontSize="10" />
                        <TextBox x:Name="SmsCodeTextBox" Grid.Row="1" MaxLength="6"
                                 VerticalContentAlignment="Center" TextChanged="SmsCodeTextBox_TextChanged" />
                    </Grid>

                    <Grid x:Name="InvitationPanel" Grid.Row="4" Visibility="Collapsed">
                        <Grid.RowDefinitions><RowDefinition Height="20" /><RowDefinition Height="38" /></Grid.RowDefinitions>
                        <TextBlock Text="邀请码  INVITATION" Foreground="{StaticResource MutedBrush}"
                                   FontFamily="Cascadia Mono,Consolas" FontSize="10" />
                        <TextBox x:Name="InvitationTextBox" Grid.Row="1" MaxLength="6"
                                 CharacterCasing="Upper" VerticalContentAlignment="Center"
                                 TextChanged="InvitationTextBox_TextChanged" />
                    </Grid>

                    <CheckBox x:Name="MobileTermsCheckBox" Grid.Row="5"
                              Content="我已阅读并同意 Catpaw 服务条款 / I agree to the terms"
                              Foreground="#D4D2C7" FontSize="10" VerticalAlignment="Center"
                              Checked="MobileTerms_Changed" Unchecked="MobileTerms_Changed" />
                    <Button x:Name="SubmitMobileButton" Grid.Row="6"
                            Content="登录 / Sign in" Style="{StaticResource PrimaryButton}"
                            Click="SubmitMobile_Click" />
                </Grid>
            </Grid>

            <Border Grid.Row="3" Background="#171714" BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,1,0,0" CornerRadius="0,0,6,6">
                <Grid Margin="20,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="StatusText" Text="Ready" Foreground="{StaticResource MutedBrush}"
                               FontSize="10" TextWrapping="Wrap" VerticalAlignment="Center"
                               Margin="0,0,12,0" />
                    <Button Grid.Column="1" Content="取消 / Cancel" Style="{StaticResource SecondaryButton}"
                            Padding="12,6" Click="Cancel_Click" />
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
