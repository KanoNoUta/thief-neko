<Window x:Class="CatapiController.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Thief Neko"
        Width="650" Height="668" MinWidth="650" MinHeight="668"
        WindowStartupLocation="CenterScreen" WindowStyle="None"
        ResizeMode="NoResize" Background="#171714"
        FontFamily="Segoe UI,Microsoft YaHei UI" Foreground="{StaticResource TextBrush}"
        Closing="Window_Closing">
    <Border Margin="10" BorderBrush="#45443D" BorderThickness="1" CornerRadius="7" Background="{StaticResource WindowBackground}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40" />
                <RowDefinition Height="76" />
                <RowDefinition Height="106" />
                <RowDefinition Height="78" />
                <RowDefinition Height="180" />
                <RowDefinition Height="*" />
                <RowDefinition Height="30" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{StaticResource PanelBackground}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" CornerRadius="6,6,0,0" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid Margin="13,0,7,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="36" />
                        <ColumnDefinition Width="36" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="18" Height="18" BorderBrush="{StaticResource PrimaryBrush}" BorderThickness="1" CornerRadius="3">
                            <TextBlock Text="C" Foreground="{StaticResource PrimaryBrush}" FontFamily="Consolas" FontWeight="Bold" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <TextBlock Text="Thief Neko" Margin="9,0,0,0" FontWeight="SemiBold" FontSize="12" VerticalAlignment="Center" />
                    </StackPanel>
                    <Button Grid.Column="1" Content="−" Style="{StaticResource SecondaryButton}" Padding="0" BorderThickness="0" Click="Minimize_Click" ToolTip="最小化" />
                    <Button Grid.Column="2" Content="×" Style="{StaticResource SecondaryButton}" Padding="0" BorderThickness="0" Click="Close_Click" ToolTip="隐藏到托盘" />
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="18,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Gateway" FontFamily="Georgia" FontSize="20" FontWeight="SemiBold" />
                    <TextBlock x:Name="EndpointText" Text="127.0.0.1:3000  ·  glm-5.2" Margin="0,5,0,0" Foreground="{StaticResource MutedBrush}" FontFamily="Cascadia Mono,Consolas" FontSize="11" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse x:Name="StatusDot" Width="8" Height="8" Fill="#77756D" Margin="0,0,8,0" />
                    <TextBlock x:Name="ServiceStateText" Text="已停止" Foreground="#B4B2A8" FontSize="12" VerticalAlignment="Center" Margin="0,0,10,0" />
                    <Button x:Name="ServiceButton" Content="启动服务" Style="{StaticResource SecondaryButton}" Click="ServiceButton_Click" MinWidth="78" />
                </StackPanel>
            </Grid>

            <Grid Grid.Row="2" Background="#1E1E1A">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,1,1" Padding="13">
                    <StackPanel><TextBlock Text="CATPAW 剩余" Foreground="{StaticResource MutedBrush}" FontSize="10" /><TextBlock x:Name="QuotaText" Text="暂无数据" Margin="0,9,0,5" FontFamily="Cascadia Mono,Consolas" FontSize="18" FontWeight="SemiBold" /><TextBlock x:Name="QuotaDetailText" Text="暂无数据" Foreground="#77766E" FontSize="10" /></StackPanel>
                </Border>
                <Border Grid.Column="1" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,1,1" Padding="13">
                    <StackPanel><TextBlock Text="输入 TOKEN (M)" Foreground="{StaticResource MutedBrush}" FontSize="10" /><TextBlock x:Name="InputTokenText" Text="暂无数据" Margin="0,9,0,5" FontFamily="Cascadia Mono,Consolas" FontSize="18" FontWeight="SemiBold" /><TextBlock Text="累计" Foreground="#77766E" FontSize="10" /></StackPanel>
                </Border>
                <Border Grid.Column="2" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,1,1" Padding="13">
                    <StackPanel><TextBlock Text="输出 TOKEN (M)" Foreground="{StaticResource MutedBrush}" FontSize="10" /><TextBlock x:Name="OutputTokenText" Text="暂无数据" Margin="0,9,0,5" FontFamily="Cascadia Mono,Consolas" FontSize="18" FontWeight="SemiBold" /><TextBlock Text="累计" Foreground="#77766E" FontSize="10" /></StackPanel>
                </Border>
                <Border Grid.Column="3" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,1" Padding="13">
                    <StackPanel><TextBlock Text="网关内存" Foreground="{StaticResource MutedBrush}" FontSize="10" /><TextBlock x:Name="MemoryText" Text="暂无数据" Margin="0,9,0,5" FontFamily="Cascadia Mono,Consolas" FontSize="18" FontWeight="SemiBold" /><TextBlock x:Name="MemoryDetailText" Text="未运行" Foreground="#77766E" FontSize="10" /></StackPanel>
                </Border>
            </Grid>

            <Grid Grid.Row="3" Margin="18,9,18,8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="28" />
                    <RowDefinition Height="33" />
                </Grid.RowDefinitions>
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                    <TextBlock Text="TOKEN 统计范围" Foreground="{StaticResource MutedBrush}" FontFamily="Cascadia Mono,Consolas" FontSize="10" VerticalAlignment="Center" />
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button x:Name="Range1Button" Content="1 天" Tag="1" Style="{StaticResource SecondaryButton}" Padding="10,4" Margin="0,0,5,0" Click="RangePreset_Click" />
                        <Button x:Name="Range7Button" Content="7 天" Tag="7" Style="{StaticResource SecondaryButton}" Padding="10,4" Margin="0,0,5,0" Click="RangePreset_Click" />
                        <Button x:Name="Range30Button" Content="30 天" Tag="30" Style="{StaticResource SecondaryButton}" Padding="10,4" Margin="0,0,5,0" Click="RangePreset_Click" />
                        <Button x:Name="RangeCustomButton" Content="自定义" Tag="0" Style="{StaticResource SecondaryButton}" Padding="10,4" Click="RangePreset_Click" />
                    </StackPanel>
                </Grid>
                <Grid Grid.Row="1" Margin="0,5,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="58" /><ColumnDefinition Width="*" />
                        <ColumnDefinition Width="18" />
                        <ColumnDefinition Width="58" /><ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="开始日期" Foreground="{StaticResource MutedBrush}" FontSize="10" VerticalAlignment="Center" />
                    <DatePicker x:Name="StartDatePicker" Grid.Column="1" Height="30" InputMethod.IsInputMethodEnabled="False" SelectedDateFormat="Short" SelectedDateChanged="DateRange_SelectedDateChanged" />
                    <TextBlock Grid.Column="3" Text="结束日期" Foreground="{StaticResource MutedBrush}" FontSize="10" VerticalAlignment="Center" />
                    <DatePicker x:Name="EndDatePicker" Grid.Column="4" Height="30" InputMethod.IsInputMethodEnabled="False" SelectedDateFormat="Short" SelectedDateChanged="DateRange_SelectedDateChanged" />
                </Grid>
            </Grid>

            <Grid Grid.Row="4" Margin="18,15">
                <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="39" /><RowDefinition Height="28" /><RowDefinition Height="Auto" /><RowDefinition Height="39" /></Grid.RowDefinitions>
                <TextBlock Text="CATPAW TOKEN" Foreground="{StaticResource MutedBrush}" FontFamily="Cascadia Mono,Consolas" FontSize="10" />
                <Grid Grid.Row="1" Margin="0,5,0,0">
                    <PasswordBox x:Name="TokenPasswordBox" PasswordChar="●" PasswordChanged="TokenPasswordBox_PasswordChanged" />
                    <TextBox x:Name="TokenRevealBox" Visibility="Collapsed" TextChanged="TokenRevealBox_TextChanged" />
                </Grid>
                <CheckBox x:Name="AutoTokenToggle" Grid.Row="2" Content="自动获取 Catpaw Token"
                          Style="{StaticResource ToggleSwitch}" VerticalAlignment="Center"
                          ToolTip="启动网关时从 Catpaw 本地登录状态同步最新 Token" />
                <Grid Grid.Row="3" Grid.ColumnSpan="1">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                    <TextBlock Text="TENANT" Foreground="{StaticResource MutedBrush}" FontFamily="Cascadia Mono,Consolas" FontSize="10" />
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,-3,0,0">
                        <Button x:Name="RevealButton" Content="显示 Token" Style="{StaticResource SecondaryButton}" Click="RevealButton_Click" Margin="0,0,8,0" />
                        <Button x:Name="SaveButton" Content="保存并重启" Style="{StaticResource PrimaryButton}" Click="SaveRestart_Click" />
                    </StackPanel>
                </Grid>
                <TextBox x:Name="TenantTextBox" Grid.Row="4" Margin="0,5,190,0" Text="5282fa6645" />
            </Grid>

            <Border Grid.Row="5" Margin="18,0,18,12" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="4" Background="#141412" Padding="12,9">
                <Grid>
                    <Grid.RowDefinitions><RowDefinition Height="22" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                    <TextBlock Text="RECENT ACTIVITY" Foreground="{StaticResource MutedBrush}" FontFamily="Cascadia Mono,Consolas" FontSize="10" />
                    <ListBox x:Name="ActivityList" Grid.Row="1" Background="Transparent" BorderThickness="0" Foreground="#AAA89E" FontFamily="Cascadia Mono,Consolas" FontSize="10" IsHitTestVisible="False" />
                </Grid>
            </Border>

            <Border Grid.Row="6" Background="#171714" CornerRadius="0,0,6,6">
                <TextBlock x:Name="FooterText" Text="配置保存在本机用户加密存储中" Foreground="#77766E" FontSize="10" Margin="18,0" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
            </Border>
        </Grid>
    </Border>
</Window>
