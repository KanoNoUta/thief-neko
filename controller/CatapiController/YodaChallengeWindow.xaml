<Window x:Class="CatapiController.YodaChallengeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Security verification" Width="390" Height="500"
        MinWidth="390" MinHeight="500" MaxWidth="390" MaxHeight="500"
        WindowStartupLocation="CenterOwner" WindowStyle="None" ResizeMode="NoResize"
        ShowInTaskbar="False" Background="#171714"
        FontFamily="Segoe UI,Microsoft YaHei UI" Foreground="{StaticResource TextBrush}"
        Closed="Window_Closed">
    <Border Margin="10" BorderBrush="#45443D" BorderThickness="1" CornerRadius="7"
            Background="{StaticResource WindowBackground}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40" />
                <RowDefinition Height="*" />
                <RowDefinition Height="48" />
            </Grid.RowDefinitions>
            <Border Background="{StaticResource PanelBackground}" BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,0,1" CornerRadius="6,6,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid Margin="13,0,7,0">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="36" /></Grid.ColumnDefinitions>
                    <TextBlock Text="安全验证 / Security verification" FontWeight="SemiBold"
                               FontSize="12" VerticalAlignment="Center" />
                    <Button Grid.Column="1" Content="×" Style="{StaticResource SecondaryButton}"
                            Padding="0" BorderThickness="0" Click="Cancel_Click" ToolTip="Close" />
                </Grid>
            </Border>
            <wv2:WebView2 x:Name="ChallengeWebView" Grid.Row="1" Margin="1" />
            <Border Grid.Row="2" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
                <Grid Margin="12,0">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                    <TextBlock x:Name="ChallengeStatusText" Text="正在加载 / Loading"
                               Foreground="{StaticResource MutedBrush}" FontSize="10"
                               VerticalAlignment="Center" />
                    <Button Grid.Column="1" Content="取消 / Cancel" Style="{StaticResource SecondaryButton}"
                            Padding="12,6" Click="Cancel_Click" />
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
